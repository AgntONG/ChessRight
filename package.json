{
  "name": "chessright",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChessRight — play chess, find brilliancies. Frontend (Cloudflare Pages) + Worker backend.",
  "license": "MIT",
  "workspaces": [
    "worker"
  ],
  "scripts": {
    "dev:web": "cd web && python -m http.server 8765",
    "dev:worker": "cd worker && npx wrangler dev",
    "check": "node --check web/scripts/*.js web/scripts/play/*.js worker/src/*.js"
  }
}
